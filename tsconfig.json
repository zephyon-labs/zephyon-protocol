{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": false,
    "types": ["node", "mocha"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
  "src/**/*.ts",
  "scripts/protocol_lab.ts",
  "scripts/simulate_payment.ts",
  "scripts/simulate_payment_batch.ts",
  "scripts/test_scenario_participants.ts",
  "tests/**/*.spec.ts",
  "tests/helpers.ts"

],
  "exclude": [
    "node_modules",
    "target",
    "dist-tests",
    "tests/_hold",
    "tests_legacy"
  ]
}